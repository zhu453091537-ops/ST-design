VITE_BASE=./

# Handoff preview must run without backend services.
VITE_USE_MOCK=true

# Keep preview routes stable when served from a nested folder.
VITE_ROUTER_HISTORY=hash

# Do not generate archive/compressed side files for the handoff preview.
VITE_ARCHIVER=false
VITE_COMPRESS=none

VITE_PWA=false
VITE_DEVTOOLS=false
VITE_INJECT_APP_LOADING=true

VITE_GLOB_API_URL=/api
VITE_GLOB_ENABLE_ENCRYPT=true
